{
  "name": "@artanis-ai/gravel",
  "version": "0.5.18",
  "description": "Embedded prompt management, tracing, and evals for AI engineering teams.",
  "license": "Apache-2.0",
  "homepage": "https://gravel.artanis.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artanis-ai/gravel.git",
    "directory": "packages/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/artanis-ai/gravel/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./auto": {
      "import": "./dist/auto.js",
      "require": "./dist/auto.cjs",
      "types": "./dist/auto.d.ts"
    },
    "./define": {
      "import": "./dist/define.js",
      "require": "./dist/define.cjs",
      "types": "./dist/define.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "require": "./dist/next.cjs",
      "types": "./dist/next.d.ts"
    },
    "./next-pages": {
      "import": "./dist/next-pages.js",
      "require": "./dist/next-pages.cjs",
      "types": "./dist/next-pages.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "require": "./dist/node.cjs",
      "types": "./dist/node.d.ts"
    },
    "./fastify": {
      "import": "./dist/fastify.js",
      "require": "./dist/fastify.cjs",
      "types": "./dist/fastify.d.ts"
    }
  },
  "bin": {
    "gravel": "./bin/gravel.js"
  },
  "files": [
    "bin",
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build-dashboard.mjs && tsup",
    "build:bundle": "node scripts/build-dashboard.mjs",
    "build:bundle:stub": "node scripts/stub-dashboard.mjs",
    "dev": "tsup --watch",
    "test": "node scripts/stub-dashboard.mjs --if-missing && vitest run",
    "test:watch": "node scripts/stub-dashboard.mjs --if-missing && vitest",
    "lint": "eslint src",
    "typecheck": "node scripts/stub-dashboard.mjs --if-missing && tsc --noEmit",
    "schema:dump": "tsx src/schema/dump.ts",
    "migrations:generate": "drizzle-kit generate --config=drizzle.config.postgres.ts && drizzle-kit generate --config=drizzle.config.sqlite.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "magicast": "^0.3.5",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "*",
    "@langchain/core": "*",
    "ai": "*",
    "better-sqlite3": "*",
    "openai": "*",
    "pg": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "better-sqlite3": "^11.5.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "pg": "^8.13.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
