{
  "name": "@artanis-ai/gravel",
  "version": "0.0.1",
  "description": "Embedded prompt management, tracing, and evals for AI engineering teams.",
  "license": "Apache-2.0",
  "homepage": "https://gravel.artanis.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artanis-ai/gravel.git",
    "directory": "packages/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/artanis-ai/gravel/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./auto": {
      "import": "./dist/auto.js",
      "require": "./dist/auto.cjs",
      "types": "./dist/auto.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "require": "./dist/next.cjs",
      "types": "./dist/next.d.ts"
    },
    "./next-pages": {
      "import": "./dist/next-pages.js",
      "require": "./dist/next-pages.cjs",
      "types": "./dist/next-pages.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "require": "./dist/node.cjs",
      "types": "./dist/node.d.ts"
    }
  },
  "bin": {
    "gravel": "./dist/cli.js"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "schema:dump": "tsx src/schema/dump.ts",
    "migrations:generate": "drizzle-kit generate --config=drizzle.config.postgres.ts && drizzle-kit generate --config=drizzle.config.sqlite.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "magicast": "^0.3.5",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "better-sqlite3": "*",
    "pg": "*"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "better-sqlite3": "^11.5.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "pg": "^8.13.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
